# Copy this file to .npmrc in your project root and replace ${GITLAB_TOKEN}
# with a personal access token scoped to read_package_registry.
#
# How to get a token:
#   git.inkyquill.net → User Settings → Access Tokens
#   Scopes: read_package_registry
#   Copy the token and either:
#     export GITLAB_TOKEN=<token>           # CI / shell
#     OR substitute it directly in .npmrc   # local dev

@inky:registry=https://git.inkyquill.net/api/v4/packages/npm/
//git.inkyquill.net/api/v4/packages/npm/:_authToken=${GITLAB_TOKEN}
